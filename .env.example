# ============================================================
#  AI HUMAN - Environment Configuration
# ============================================================
#
#  Copy this file to .env and fill in your values.
#  Only the settings for your chosen provider are required.
# ============================================================

# ── PROVIDER SELECTION ──────────────────────────────────────
# Options: anthropic | openai | ollama | lmstudio | custom
LLM_PROVIDER=ollama

# ── MODEL NAME ──────────────────────────────────────────────
# Leave blank to auto-select based on your hardware.
# Examples:
#   ollama   → llama3.2:3b  / mistral:7b / phi3:mini
#   lmstudio → llama-3.2-3b-instruct / mistral-7b-instruct-v0.3
#   openai   → gpt-4o-mini / gpt-4o
#   anthropic→ claude-sonnet-4-6 / claude-haiku-4-5-20251001
LLM_MODEL=

# ── API KEYS (only needed for cloud providers) ───────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── LOCAL PROVIDER URLS ──────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234

# ── CUSTOM OPENAI-COMPATIBLE ENDPOINT ───────────────────────
# Any server that speaks /v1/chat/completions
CUSTOM_BASE_URL=
CUSTOM_API_KEY=
CUSTOM_MODEL=

# ── VISION MODEL (optional, for screen understanding) ────────
# If blank, falls back to OCR-only perception
# For Ollama: llava:7b / llava:13b / moondream / minicpm-v
# For low-RAM: moondream  (1.8B, runs on 2GB RAM)
VISION_MODEL=
VISION_PROVIDER=  # leave blank to use same as LLM_PROVIDER

# ── HARDWARE OVERRIDE (auto-detected if blank) ───────────────
# RAM_GB=8
# VRAM_GB=0
# CPU_CORES=4

# ── PERFORMANCE ──────────────────────────────────────────────
# How often the agent loop ticks (seconds)
LOOP_INTERVAL_SECONDS=3
# Max tokens to generate per reasoning step
MAX_TOKENS=1024
# Context window to use (auto-set from model if blank)
CONTEXT_WINDOW=

# ── SAFETY ───────────────────────────────────────────────────
# Risk score threshold requiring user confirmation (1-10)
SAFETY_CONFIRM_THRESHOLD=7
# Risk score threshold for hard block (1-10)
SAFETY_BLOCK_THRESHOLD=9

# ── MEMORY ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=data/chroma
MAX_MEMORY_RESULTS=5

# ── AVATAR ───────────────────────────────────────────────────
SHOW_AVATAR=true

# ── Security: Remote Server Authentication ────────────────────
# Generate a strong random token:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave blank to disable token auth (only safe on trusted local network)
REMOTE_API_TOKEN=
MOBILE_API_TOKEN=

# ── Email (for email skill pack) ─────────────────────────────
# SMTP/IMAP credentials for email_send, email_read, email_search tools
EMAIL_USER=
EMAIL_PASS=

# ── Database (for database skill pack) ───────────────────────
# POSTGRES_PASSWORD=
# MYSQL_PASSWORD=

# ── Credential Vault ──────────────────────────────────────────
# Passphrase to unlock the encrypted credential vault
AI_HUMAN_VAULT_PASS=
